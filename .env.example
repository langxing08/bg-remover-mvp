# Copy this file to .env and fill in your key:
#   cp .env.example .env
# Then edit .env and add your remove.bg API key.
#
# In production, set REMOVE_BG_API_KEY via Cloudflare Pages
# environment variables (secret_text type).
REMOVE_BG_API_KEY=your-key-here
